---
import Base from '../layouts/Base.astro';
---

<Base title="Selected Work — Harasyn.co" topbarVariant="page">
  <div class="text-page-title">
    <h1 class="text_quote">Selected Work</h1>
  </div>

  <div class="project">
    <div class="project-cover">
      <img src="/assets/mansion_global_mobile.jpg" class="visible-mobile">
      <img src="/assets/mansion_global.jpg" class="hidden-mobile">
    </div>
    <div class="project-content">
      <div class="project-title">
        <a href="http://www.mansionglobal.com" target="_blank">Mansion Global<img src="/assets/open-window-icon.svg" style="height: 13px; padding-left: 1ch;"></a>
        <p>News Corp.</p>
      </div>
      <div class="project-details">
        <h2>Luxury Real Estate, Global Market</h2>
        <p class="text">Creating the premier digital destination serving the needs of the world's most affluent real estate buyers.</p>
        <div class="tag-container">
          <p>Product Strategy and Research・Design Direction・IxD・Brand Development・Responsive Design・Global Infrastructure・Executive Stakeholders・Global Real Estate</p>
        </div>
      </div>
    </div>
  </div>

